# ============================================
# Variables de entorno para CajasComunales
# ============================================

# NODE ENVIRONMENT
NODE_ENV=production

# ============================================
# BASE DE DATOS
# ============================================

# Host de la base de datos (use 'db' para Docker, 'localhost' para desarrollo local)
DB_HOST=db

# Puerto PostgreSQL
DB_PORT=5432

# Nombre de la base de datos
DB_NAME=cajasComunales

# Usuario de PostgreSQL
DB_USER=postgres

# Contraseña de PostgreSQL (CAMBIAR EN PRODUCCIÓN)
DB_PASSWORD=root

# ============================================
# BACKEND API
# ============================================

# Puerto del servidor backend
PORT=3000

# SECRET para firmar JWT tokens (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=your-secret-key-change-in-production

# Tiempo de expiración del access token (ej: 15m, 1h)
ACCESS_TOKEN_EXPIRY=15m

# Tiempo de expiración del refresh token (ej: 7d, 30d)
REFRESH_TOKEN_EXPIRY=7d

# ============================================
# FRONTEND
# ============================================

# URL de la API en desarrollo local
VITE_API_URL=http://localhost:3000

# ============================================
# DOCKER & SERVICIOS
# ============================================

# Nombre del contenedor de base de datos
DB_CONTAINER_NAME=cajas-comunales-db

# Nombre del contenedor de backend
BACKEND_CONTAINER_NAME=cajas-comunales-backend

# Nombre del contenedor de frontend
FRONTEND_CONTAINER_NAME=cajas-comunales-frontend

# Red de Docker
DOCKER_NETWORK=cajas-comunales-network
